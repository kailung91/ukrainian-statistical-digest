# AI Provider: "gemini" (default) або "claude"
VITE_AI_PROVIDER=gemini

# Gemini API key — отримати на: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=

# Gemini model: gemini-2.5-flash | gemini-2.5-pro | gemini-2.0-flash
VITE_GEMINI_MODEL=gemini-2.5-flash

# Claude API key — fallback provider
VITE_ANTHROPIC_API_KEY=

# Claude model
VITE_CLAUDE_MODEL=claude-sonnet-4-6
